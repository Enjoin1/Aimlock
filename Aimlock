-- === ESP ENGINE (Drawing API) ===
local ESPCache = {}

local function UpdateESP()
    if not Config.ESP.Enabled then
        for _, obj in pairs(ESPCache) do
            if obj.Box then obj.Box.Visible = false end
            if obj.Name then obj.Name.Visible = false end
        end
        return
    end

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            local head = plr.Character:FindFirstChild("Head")

            if humanoid and root and head and humanoid.Health > 0 then
                local isTeam = Config.ESP.TeamCheck and plr.Team == player.Team
                local screenPos, onScreen = camera:WorldToViewportPoint(root.Position)

                if not ESPCache[plr.UserId] then
                    ESPCache[plr.UserId] = {
                        Box = Drawing.new("Square"),
                        Name = Drawing.new("Text")
                    }
                end

                local cache = ESPCache[plr.UserId]
                
                -- Box ESP
                cache.Box.Visible = onScreen
                if onScreen then
                    local size = root.Size
                    local scale = size.Y / (screenPos.Z * math.tan(math.rad(camera.FieldOfView / 2)) * 2) * camera.ViewportSize.Y
                    cache.Box.Size = Vector2.new(scale * 0.8, scale * 1.8)
                    cache.Box.Position = Vector2.new(screenPos.X - cache.Box.Size.X/2, screenPos.Y - cache.Box.Size.Y/2)
                    cache.Box.Color = isTeam and Config.ESP.TeamColor or Config.ESP.BoxColor
                    cache.Box.Thickness = 1
                    cache.Box.Filled = false
                end

                -- Name ESP
                cache.Name.Visible = onScreen
                if onScreen then
                    cache.Name.Text = plr.Name .. (isTeam and " [TEAM]" or "")
                    cache.Name.Position = Vector2.new(screenPos.X, screenPos.Y - 30)
                    cache.Name.Center = true
                    cache.Name.Outline = true
                    cache.Name.Size = Config.ESP.TextSize
                    cache.Name.Color = isTeam and Config.ESP.TeamColor or Config.ESP.BoxColor
                end
            end
        end
    end
end

-- === AIMBOT LOGIC ===
local function GetValidTarget()
    local closest, minDist = nil, math.huge
    local center = camera.ViewportSize / 2

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local part = plr.Character:FindFirstChild(Config.Aimbot.TargetPart)
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            
            if part and hum and hum.Health > 0 then
                if Config.Aimbot.TeamCheck and plr.Team == player.Team then continue end
                
                local pos, visible = camera:WorldToScreenPoint(part.Position)
                if visible then
                    local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if dist <= Config.Aimbot.FOV and dist < minDist then
                        if Config.Aimbot.WallCheck then
                            local params = RaycastParams.new()
                            params.FilterDescendantsInstances = {player.Character}
                            params.FilterType = Enum.RaycastFilterType.Exclude
                            local ray = workspace:Raycast(camera.CFrame.Position, (part.Position - camera.CFrame.Position).Unit * 1000, params)
                            if ray and ray.Instance:FindFirstAncestor(plr.Name) then
                                closest, minDist = plr, dist
                            end
                        else
                            closest, minDist = plr, dist
                        end
                    end
                end
            end
        end
    end
    return closest
end

-- Single Heartbeat Loop (Prevents memory leaks)
RunService.RenderStepped:Connect(function(dt)
    UpdateESP()
    
    if not Config.Aimbot.Enabled then 
        State.Aiming = false
        State.LockedTarget = nil
        return 
    end

    -- Determine active target based on mode
    local target = nil
    if Config.Aimbot.HoldToAim then
        target = State.Aiming and GetValidTarget() or nil
    else
        if State.LockedTarget then
            -- Validate locked target still exists
            local char = State.LockedTarget.Character
            if char and char:FindFirstChild(Config.Aimbot.TargetPart) then
                target = State.LockedTarget
            else
                State.LockedTarget = nil
            end
        end
    end

    -- Execute aim
    if target then
        local part = target.Character:FindFirstChild(Config.Aimbot.TargetPart)
        if part then
            local goal = CFrame.lookAt(camera.CFrame.Position, part.Position)
            -- Frame-rate independent smoothing
            local alpha = math.clamp(Config.Aimbot.Smoothness * dt * 60, 0, 1)
            camera.CFrame = camera.CFrame:Lerp(goal, alpha)
        end
    end
end)

-- === TOUCH INPUT HANDLER ===
UserInputService.TouchStarted:Connect(function(touch, processed)
    if processed or not Config.Aimbot.Enabled then return end
    
    if Config.Aimbot.HoldToAim then
        State.Aiming = true
        State.TouchId = touch.Position -- Simple ID tracking
    else
        -- Tap to lock nearest
        State.LockedTarget = GetValidTarget()
    end
end)

UserInputService.TouchEnded:Connect(function(touch, processed)
    if Config.Aimbot.HoldToAim and State.Aiming then
        State.Aiming = false
        State.TouchId = nil
    end
end)

