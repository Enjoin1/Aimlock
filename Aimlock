--[[
    Lock-On Camera System for Roblox Mobile
    - Sử dụng CFrame.lookAt để xoay camera mượt mà không bị cảm ứng ghi đè.
    - Tự động huỷ mục tiêu khi nó ra khỏi vòng tròn 35px (người chơi vuốt camera).
    - Vòng tròn giới hạn xanh lá (Drawing API), kiểm tra vật cản qua workspace:Raycast.
    - Nút Toggle AIM kéo thả được trên màn hình.
    Chạy trên Executor Delta.
]]

-- Dịch vụ
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local Camera = Workspace.CurrentCamera

local player = Players.LocalPlayer

-- Trạng thái
local aimEnabled = false
local target = nil -- Part "Head" của mục tiêu
local aimConnection = nil

-- Vòng tròn xanh ở tâm màn hình (Drawing)
local circle = Drawing.new("Circle")
circle.Radius = 35
circle.Color = Color3.fromRGB(0, 255, 0)
circle.Thickness = 2
circle.Filled = false
circle.Visible = false
circle.Position = Camera.ViewportSize / 2

-- Cập nhật vị trí vòng tròn khi độ phân giải thay đổi
Camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
    circle.Position = Camera.ViewportSize / 2
end)

-- ========== GIAO DIỆN NÚT TOGGLE ==========
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")

local toggleButton = Instance.new("TextButton")
toggleButton.Size = UDim2.new(0, 100, 0, 40)
toggleButton.Position = UDim2.new(0, 20, 0, 20)
toggleButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleButton.Text = "AIM: OFF"
toggleButton.Font = Enum.Font.SourceSansBold
toggleButton.TextSize = 14
toggleButton.BorderSizePixel = 0
toggleButton.AutoButtonColor = false
toggleButton.Parent = screenGui

-- Logic kéo / thả bằng cảm ứng
local activeTouch = nil
local dragStart = nil
local startPos = nil
local dragging = false

toggleButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        if not activeTouch then
            activeTouch = input
            dragStart = input.Position
            startPos = toggleButton.Position
            dragging = false
        end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == activeTouch then
        local delta = input.Position - dragStart
        if delta.Magnitude > 5 then
            dragging = true
        end
        if dragging then
            local newPosX = startPos.X.Offset + delta.X
            local newPosY = startPos.Y.Offset + delta.Y
            toggleButton.Position = UDim2.new(0, newPosX, 0, newPosY)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input == activeTouch then
        if not dragging then
            -- Chạm nhẹ -> bật / tắt
            aimEnabled = not aimEnabled
            updateAimState()
        end
        activeTouch = nil
        dragging = false
    end
end)

-- ========== HÀM CHỨC NĂNG ==========

function updateAimState()
    if aimEnabled then
        toggleButton.Text = "AIM: ON"
        toggleButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        circle.Visible = true
        startAimLoop()
    else
        toggleButton.Text = "AIM: OFF"
        toggleButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        circle.Visible = false
        stopAimLoop()
    end
end

function startAimLoop()
    if aimConnection then return end
    aimConnection = RunService.RenderStepped:Connect(function()
        if aimEnabled then
            updateAim()
        end
    end)
end

function stopAimLoop()
    if aimConnection then
        aimConnection:Disconnect()
        aimConnection = nil
    end
    target = nil
end

-- Lấy danh sách mục tiêu tiềm năng (các Head của người chơi khác hoặc NPC có Humanoid)
function getPotentialTargets()
    local targets = {}
    local camPos = Camera.CFrame.Position
    local screenCenter = Camera.ViewportSize / 2

    for _, otherPlayer in ipairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            local char = otherPlayer.Character
            if char then
                local head = char:FindFirstChild("Head")
                local humanoid = char:FindFirstChild("Humanoid")
                if head and humanoid and humanoid.Health > 0 then
                    local screenPos, onScreen = Camera:WorldToScreenPoint(head.Position)
                    if onScreen then
                        local pos2D = Vector2.new(screenPos.X, screenPos.Y)
                        local distToCenter = (pos2D - screenCenter).Magnitude
                        if distToCenter <= 35 then
                            table.insert(targets, {
                                part = head,
                                dist = distToCenter,
                                screenPos = pos2D
                            })
                        end
                    end
                end
            end
        end
    end

    -- Sắp xếp từ gần tâm màn hình nhất
    table.sort(targets, function(a, b) return a.dist < b.dist end)
    return targets
end

-- Kiểm tra xem giữa camera và mục tiêu có vật cản không
function isLineOfSightClear(targetPart)
    local character = player.Character
    if not character then return false end

    local rayOrigin = Camera.CFrame.Position
    local rayDestination = targetPart.Position
    local rayDirection = (rayDestination - rayOrigin)
    local rayDistance = rayDirection.Magnitude
    if rayDistance <= 0 then return true end
    rayDirection = rayDirection / rayDistance -- Unit

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    -- Bỏ qua nhân vật người chơi và nhân vật của mục tiêu
    rayParams.FilterDescendantsInstances = {character, targetPart.Parent}

    local rayResult = Workspace:Raycast(rayOrigin, rayDirection * rayDistance, rayParams)
    if rayResult then
        -- Nếu vật cản là một phần của target (vd: trúng chính Head) thì coi như thông suốt
        return rayResult.Instance:IsDescendantOf(targetPart.Parent)
    else
        return true -- Không va chạm
    end
end

-- Cập nhật logic mỗi khung hình
function updateAim()
    if target then
        -- Kiểm tra mục tiêu còn tồn tại và còn sống
        local head = target
        if not head or not head.Parent then
            target = nil
            return
        end
        local humanoid = head.Parent:FindFirstChild("Humanoid")
        if not humanoid or humanoid.Health <= 0 then
            target = nil
            return
        end

        -- Kiểm tra vị trí 2D của Head so với tâm màn hình
        local screenPos, onScreen = Camera:WorldToScreenPoint(head.Position)
        if not onScreen then
            target = nil
            return
        end
        local distToCenter = (Vector2.new(screenPos.X, screenPos.Y) - Camera.ViewportSize / 2).Magnitude
        if distToCenter > 35 then
            -- Người chơi đã xoay camera khiến mục tiêu ra ngoài vòng tròn -> huỷ
            target = nil
            return
        end

        -- Kiểm tra vật cản
        if not isLineOfSightClear(head) then
            target = nil
            return
        end

        -- Ép camera hướng thẳng vào Head của mục tiêu (giữ nguyên vị trí)
        -- Dùng CFrame.lookAt để tránh bị cảm ứng mobile ghi đè
        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, head.Position)
    else
        -- Chưa có mục tiêu -> quét và chọn mục tiêu gần tâm nhất, không bị che
        local potentials = getPotentialTargets()
        for _, t in ipairs(potentials) do
            if isLineOfSightClear(t.part) then
                target = t.part
                break
            end
        end
    end
end

-- Khởi tạo trạng thái ban đầu
updateAimState()
