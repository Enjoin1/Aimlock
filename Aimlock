-- PHAN 1: KHAI BAO
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local Settings = {
    Aimlock = false,
    ESP = false,
    ESPName = false,
    ESPHealth = false,
    ESPDistance = false,
    ESPTeam = false,
    ShowTeammates = false,
    IgnoreWalls = false,
    AimPart = "Head",
    NoRecoil = false,
    InfiniteAmmo = false,
}

local FOV_RADIUS = 140
local UNLOCK_DISTANCE = FOV_RADIUS
local Target = nil
local ESPCache = {}
local espObjects = {}
local isMenuOpen = true
