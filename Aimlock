-- Script: Cơ chế ngắm tự động (Aim Assist/Aimlock) + Hiển thị FOV Circle UI cho Mobile
-- Tác giả: Qwen
-- Mô tả: Cung cấp chức năng ngắm vào nhân vật gần nhất trong tầm nhìn khi nhấn phím và hiển thị vòng tròn FOV bằng UI.
--       YÊU CẦU: Bạn phải tạo Frame UI hình tròn trong Roblox Studio như mô tả trong comment.

-- // Dịch vụ Roblox
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- // Cấu hình (có thể dễ dàng điều chỉnh)
local CONFIG = {
    AimKey = Enum.KeyCode.ButtonR2, -- Nút kích hoạt (thường là R2 trên mobile controller)
    MaxDistance = 300,              -- Khoảng cách tối đa để ngắm (studs)
    CircleRadius = 0.35,            -- Bán kính vùng FOV (0.0 đến 0.5 tương ứng 0% đến 50% chiều rộng/màn hình)
    Smoothness = 0.3,               -- Độ mượt của chuyển động ngắm
    TeamCheck = false,              -- Nếu true, sẽ bỏ qua đồng đội
    VisibilityCheck = false,        -- Nếu true, sẽ kiểm tra tầm nhìn
    ShowFOVCircle = true,           -- Nếu true, sẽ hiển thị vòng tròn FOV UI
    FOVCircleUIName = "AimFOVCircle" -- Tên của Frame UI hình tròn trong PlayerGui/ScreenGui
}

-- // Tham chiếu đến Frame UI
local fovCircleUI = nil

-- // Hàm tìm kiếm Frame UI trong PlayerGui
local function FindFOVCircleUI()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    local screenGui = playerGui:FindFirstChildWhichIsA("ScreenGui") -- Hoặc tìm theo tên cụ thể nếu bạn có
    if screenGui then
        fovCircleUI = screenGui:WaitForChild(CONFIG.FOVCircleUIName)
        if fovCircleUI and fovCircleUI:IsA("Frame") then
            -- Đảm bảo UICorner tồn tại để tạo hình tròn
            local uiCorner = fovCircleUI:FindFirstChildOfClass("UICorner")
            if not uiCorner then
                warn("UI Frame '" .. CONFIG.FOVCircleUIName .. "' không có UICorner. UI có thể không hiển thị tròn.")
            end
            -- Ẩn UI theo mặc định
            fovCircleUI.Visible = false
            print("Tìm thấy và kết nối với UI '" .. CONFIG.FOVCircleUIName .. "'")
        else
            warn("Không tìm thấy Frame UI tên '" .. CONFIG.FOVCircleUIName .. "' hoặc nó không phải là Frame.")
        end
    else
        warn("Không tìm thấy ScreenGui trong PlayerGui.")
    end
end

-- // Hàm cập nhật kích thước của Frame UI FOV dựa trên CircleRadius và ViewportSize
local function UpdateFOVCircleUISize()
    if not fovCircleUI then return end
    local viewportSize = Camera.ViewportSize
    -- Tính bán kính theo pixel dựa trên CircleRadius
    local radiusInPixels = (CONFIG.CircleRadius * math.min(viewportSize.X, viewportSize.Y))
    -- Đặt kích thước của Frame là đường kính
    fovCircleUI.Size = UDim2.new(0, radiusInPixels * 2, 0, radiusInPixels * 2)
end

-- // Hàm lấy nhân vật gần nhất trong tầm ngắm (giống như trước)
local function GetClosestEnemy()
    local closestPlayer = nil
    local bestScore = math.huge

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local character = player.Character
            if character then
                local rootPart = character:FindFirstChild("HumanoidRootPart")
                local humanoid = character:FindFirstChild("Humanoid")

                if rootPart and humanoid and humanoid.Health > 0 then
                    if CONFIG.TeamCheck and LocalPlayer.Team and player.Team and LocalPlayer.Team == player.Team then
                        continue
                    end

                    local screenPosition, onScreen = Camera:WorldToViewportPoint(rootPart.Position)

                    if onScreen then
                        local dx = (screenPosition.X / Camera.ViewportSize.X) - 0.5
                        local dy = (screenPosition.Y / Camera.ViewportSize.Y) - 0.5
                        local distanceFromCenter = math.sqrt(dx^2 + dy^2)

                        if distanceFromCenter < CONFIG.CircleRadius then
                            local distance3D = (Camera.CFrame.Position - rootPart.Position).Magnitude

                            if distance3D <= CONFIG.MaxDistance then
                                if CONFIG.VisibilityCheck then
                                    local rayParams = RaycastParams.new()
                                    rayParams.FilterDescendantsInstances = {LocalPlayer.Character, character}
                                    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
                                    local rayResult = workspace:Raycast(Camera.CFrame.Position, (rootPart.Position - Camera.CFrame.Position).Unit * distance3D, rayParams)
                                    if rayResult then
                                        continue
                                    end
                                end

                                if distance3D < bestScore then
                                    bestScore = distance3D
                                    closestPlayer = rootPart
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    return closestPlayer
end

-- // Hàm di chuyển camera mượt mà về phía mục tiêu (giống như trước)
local function SmoothAim(target)
    if not target then return end

    local targetPosition = target.Position
    local cameraPosition = Camera.CFrame.Position
    local direction = (targetPosition - cameraPosition).Unit
    local newCFrame = CFrame.lookAt(cameraPosition, cameraPosition + direction)

    Camera.CFrame = Camera.CFrame:Lerp(newCFrame, CONFIG.Smoothness)
end

-- // Biến trạng thái và kết nối sự kiện (giống như trước)
local isAiming = false
local aimConnection = nil

-- // Khởi tạo: Tìm UI và cập nhật kích thước ban đầu nếu UI tồn tại
FindFOVCircleUI()
if fovCircleUI then
    -- Cập nhật kích thước khi kích thước viewport thay đổi
    Camera:GetPropertyChangedSignal("ViewportSize"):Connect(UpdateFOVCircleUISize)
    -- Cập nhật kích thước lần đầu tiên nếu UI được tìm thấy
    UpdateFOVCircleUISize()
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == CONFIG.AimKey then
        if not isAiming then
            isAiming = true
            if aimConnection then
                aimConnection:Disconnect()
            end

            -- Hiển thị UI FOV Circle khi bắt đầu aim (nếu UI tồn tại)
            if CONFIG.ShowFOVCircle and fovCircleUI then
                fovCircleUI.Visible = true
                -- Kích thước đã được cập nhật động qua connection ở trên
            end

            aimConnection = RunService.RenderStepped:Connect(function()
                if not UserInputService:IsKeyDown(CONFIG.AimKey) then
                    isAiming = false
                    if aimConnection then
                        aimConnection:Disconnect()
                        aimConnection = nil
                    end
                    -- Ẩn UI FOV Circle khi ngừng aim (nếu UI tồn tại)
                    if CONFIG.ShowFOVCircle and fovCircleUI then
                        fovCircleUI.Visible = false
                    end
                    return
                end

                local target = GetClosestEnemy()
                if target then
                    SmoothAim(target)
                end
            end)
        end
    end
end)

