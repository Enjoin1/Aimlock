local function IsAlive(character)
    if not character then return false end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    return hrp and humanoid and humanoid.Health > 0
end

local function IsTeammate(player)
    if player == LocalPlayer then return false end
    local myTeam = LocalPlayer.Team
    local theirTeam = player.Team
    return myTeam and theirTeam and myTeam == theirTeam
end

local rayParams = RaycastParams.new()
rayParams.FilterType = Enum.RaycastFilterType.Blacklist
rayParams.IgnoreWater = true

local function IsVisible(character)
    if not character then return false end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local origin = Camera.CFrame.Position
    local direction = hrp.Position - origin
    rayParams.FilterDescendantsInstances = {LocalPlayer.Character, character}
    local result = workspace:Raycast(origin, direction, rayParams)
    if not result then return true end
    return result.Instance:IsDescendantOf(character)
end

local function GetRandomOffset()
    if not Settings.RandomOffset then return Vector3.new(0,0,0) end
    return Vector3.new(
        math.random(-Settings.OffsetMax*10, Settings.OffsetMax*10)/10,
        math.random(-Settings.OffsetMax*10, Settings.OffsetMax*10)/10,
        math.random(-Settings.OffsetMax*10, Settings.OffsetMax*10)/10
    )
end

local function GetTargets()
    local targets = {}
    local center = Camera.ViewportSize / 2
    local fovRadius = Settings.FOVCircle and Settings.FOVRadius or math.huge

    for _, plr in pairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if Settings.IgnoreTeammates and IsTeammate(plr) then continue end
        local char = plr.Character
        if not IsAlive(char) then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        local targetPos
        if Settings.AimPart == "Head" then
            local head = char:FindFirstChild("Head")
            targetPos = head and head.Position or hrp.Position
        else
            targetPos = hrp.Position
        end
        local screenPos, onScreen = Camera:WorldToViewportPoint(targetPos)
        if not onScreen then continue end
        if not Settings.IgnoreWalls and not IsVisible(char) then continue end
        local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
        if dist > fovRadius then continue end
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        table.insert(targets, {
            Player = plr,
            Character = char,
            Part = targetPos,
            Distance = (Camera.CFrame.Position - targetPos).Magnitude,
            HP = humanoid and humanoid.Health or 0,
            ScreenDist = dist,
        })
    end

    if #targets == 0 then return nil end
    if Settings.TargetMode == "LowestHP" then
        table.sort(targets, function(a,b) return a.HP < b.HP end)
    elseif Settings.TargetMode == "HighestHP" then
        table.sort(targets, function(a,b) return a.HP > b.HP end)
    else
        table.sort(targets, function(a,b) return a.ScreenDist < b.ScreenDist end)
    end
    return targets[1]
end

local function NoRecoil()
    local char = LocalPlayer.Character
    if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return end
    for _, v in pairs(tool:GetDescendants()) do
        if v:IsA("NumberValue") or v:IsA("IntValue") or v:IsA("FloatValue") then
            local name = v.Name:lower()
            if name:find("recoil") or name:find("kick") or name:find("shake") or name:find("spread") or name:find("bounce") then
                v.Value = 0
            end
        end
        if v:IsA("CFrameValue") and v.Name:lower():find("recoil") then
            v.Value = CFrame.new()
        end
        if v:IsA("Vector3Value") and v.Name:lower():find("recoil") then
            v.Value = Vector3.new(0,0,0)
        end
    end
end

local function InfiniteAmmo()
    local char = LocalPlayer.Character
    if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return end
    for _, v in pairs(tool:GetDescendants()) do
        if v:IsA("NumberValue") or v:IsA("IntValue") or v:IsA("FloatValue") then
            local name = v.Name:lower()
            if name:find("ammo") or name:find("clip") or name:find("mag") or name:find("bullet") or name:find("reserve") or name:find("max") then
                v.Value = 999
            end
        end
    end
end

local function Triggerbot()
    if not Settings.Triggerbot then return end
    local target = GetTargets()
    if target then
        mouse1click()
    end
end

