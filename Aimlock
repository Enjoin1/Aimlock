-- Keo tha toggle button
ToggleBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        isDragging = true
        dragStart = input.Position
        dragOffset = ToggleBtn.Position
    end
end)

ToggleBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        isDragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if isDragging and input.UserInputType == Enum.UserInputType.Touch then
        local delta = input.Position - dragStart
        ToggleBtn.Position = UDim2.new(
            dragOffset.X.Scale,
            dragOffset.X.Offset + delta.X,
            dragOffset.Y.Scale,
            dragOffset.Y.Offset + delta.Y
        )
    end
end)

-- PHAN 6: ESP UPDATE
local function UpdateESP()
    for _, esp in pairs(espObjects) do
        DestroyESPDrawing(esp)
    end
    espObjects = {}

    if not Settings.Aimlock or not Settings.ESP then return end

    for _, plr in pairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if not Settings.ShowTeammates and IsTeammate(plr) then continue end
        local esp = CreateESPDrawing(plr)
        if esp then
            espObjects[plr] = esp
        end
    end
end

-- PHAN 7: NO RECOIL + INFINITE AMMO
local function NoRecoil()
    if not Settings.NoRecoil then return end
    local char = LocalPlayer.Character
    if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return end
    for _, v in pairs(tool:GetDescendants()) do
        if v:IsA("NumberValue") or v:IsA("IntValue") or v:IsA("FloatValue") then
            local name = v.Name:lower()
            if name:find("recoil") or name:find("kick") or name:find("shake") or name:find("spread") then
                v.Value = 0
            end
        end
    end
end

local function InfiniteAmmo()
    if not Settings.InfiniteAmmo then return end
    local char = LocalPlayer.Character
    if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return end
    for _, v in pairs(tool:GetDescendants()) do
        if v:IsA("NumberValue") or v:IsA("IntValue") or v:IsA("FloatValue") then
            local name = v.Name:lower()
            if name:find("ammo") or name:find("clip") or name:find("mag") or name:find("bullet") then
                v.Value = 999
            end
        end
    end
end

-- PHAN 8: VONG LAP CHINH
RunService.RenderStepped:Connect(function()
    if not Settings.Aimlock then
        if FOVCircle then FOVCircle.Visible = false end
        for _, esp in pairs(espObjects) do
            esp.Name.Visible = false
            esp.Health.Visible = false
            esp.Distance.Visible = false
        end
        return
    end

    -- Cap nhat FOV Circle
    if FOVCircle then
        local center = Camera.ViewportSize / 2
        FOVCircle.Position = Vector2.new(center.X, center.Y)
        FOVCircle.Visible = true
    end

    -- No Recoil + Infinite Ammo
    NoRecoil()
    InfiniteAmmo()

    -- Tim muc tieu
    local newTarget = GetTargets()
    
    -- Kiem tra unlock khi vuot manh
    if Target and newTarget then
        if newTarget.ScreenDist > UNLOCK_DISTANCE then
            Target = nil
        else
            -- Giữ target cũ nếu vẫn trong FOV
        end
    end
    
    if newTarget and not Target then
        Target = newTarget
    end
    
    if Target then
        -- Kiem tra unlock tiep
        local center = Camera.ViewportSize / 2
        local targetScreenPos, onScreen = Camera:WorldToViewportPoint(Target.Part)
        if onScreen then
            local dist = (Vector2.new(targetScreenPos.X, targetScreenPos.Y) - center).Magnitude
            if dist > UNLOCK_DISTANCE then
                Target = nil
            end
        else
            Target = nil
        end
    end

    -- Aimlock
    if Target and Target.Part then
        local targetPos = Target.Part
        local camPos = Camera.CFrame.Position
        Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(camPos, targetPos), 0.7)
    end

    -- ESP
    if Settings.ESP then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr == LocalPlayer then continue end
            if not Settings.ShowTeammates and IsTeammate(plr) then continue end
            local char = plr.Character
            if not IsAlive(char) then continue end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then continue end
            
            local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            local esp = espObjects[plr]
            
            if esp and onScreen then
                local isTeammate = Settings.ESPTeam and IsTeammate(plr)
                local teamColor = isTeammate and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,0,0)
                local distance = (Camera.CFrame.Position - hrp.Position).Magnitude
                
                -- Name
                if Settings.ESPName then
                    esp.Name.Position = Vector2.new(screenPos.X, screenPos.Y - 40)
                    esp.Name.Text = plr.Name
                    esp.Name.Color = teamColor
                    esp.Name.Visible = true
                else
                    esp.Name.Visible = false
                end
                
                -- Health
                if Settings.ESPHealth then
                    local humanoid = char:FindFirstChildOfClass("Humanoid")
                    if humanoid then
                        local healthPercent = humanoid.Health / humanoid.MaxHealth
                        esp.Health.Position = Vector2.new(screenPos.X - 30, screenPos.Y + 10)
                        esp.Health.Size = Vector2.new(60 * healthPercent, 6)
                        esp.Health.Color = Color3.fromRGB(255 - 255 * healthPercent, 255 * healthPercent, 0)
                        esp.Health.Visible = true
                    else
                        esp.Health.Visible = false
                    end
                else
                    esp.Health.Visible = false
                end
                
                -- Distance
                if Settings.ESPDistance then
                    esp.Distance.Position = Vector2.new(screenPos.X, screenPos.Y + 25)
                    esp.Distance.Text = string.format("%.1fm", distance)
                    esp.Distance.Visible = true
                else
                    esp.Distance.Visible = false
                end
            elseif esp then
                esp.Name.Visible = false
                esp.Health.Visible = false
                esp.Distance.Visible = false
            end
        end
    end
end)

