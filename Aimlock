-- PHAN 5: ESP SU DUNG DRAWING API
local hasDrawing = pcall(function() return Drawing end)
local espObjects = {}

local function CreateESPDrawing(player)
    if not hasDrawing then return nil end
    local box = Drawing.new("Square")
    box.Thickness = 2
    box.Color = Color3.fromRGB(255,0,0)
    box.Transparency = 0.5
    box.Filled = false
    box.Visible = false

    local nameTag = Drawing.new("Text")
    nameTag.Text = player.Name
    nameTag.Color = Color3.fromRGB(255,255,255)
    nameTag.Size = 14
    nameTag.Center = true
    nameTag.Outline = true
    nameTag.OutlineColor = Color3.fromRGB(0,0,0)
    nameTag.Visible = false

    local healthBar = Drawing.new("Rectangle")
    healthBar.Color = Color3.fromRGB(0,255,0)
    healthBar.Filled = true
    healthBar.Visible = false

    local distanceText = Drawing.new("Text")
    distanceText.Color = Color3.fromRGB(200,200,200)
    distanceText.Size = 12
    distanceText.Center = true
    distanceText.Outline = true
    distanceText.OutlineColor = Color3.fromRGB(0,0,0)
    distanceText.Visible = false

    return {
        Box = box,
        Name = nameTag,
        Health = healthBar,
        Distance = distanceText,
        Player = player
    }
end

local function DestroyESPDrawing(esp)
    if esp then
        pcall(function()
            esp.Box:Remove()
            esp.Name:Remove()
            esp.Health:Remove()
            esp.Distance:Remove()
        end)
    end
end

-- PHAN 6: UPDATE ESP
local function UpdateESP()
    for _, esp in pairs(espObjects) do
        DestroyESPDrawing(esp)
    end
    espObjects = {}

    if not Settings.ESP then return end

    for _, plr in pairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if not Settings.ShowTeammates and IsTeammate(plr) then continue end
        local esp = CreateESPDrawing(plr)
        if esp then
            espObjects[plr] = esp
        end
    end
end

