-- === AIMBOT ENGINE WITH PREDICTION ===
local function GetValidTarget()
    local closest, minDist = nil, math.huge
    local center = camera.ViewportSize / 2

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local part = plr.Character:FindFirstChild(Config.Aimbot.TargetPart)
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            local root = plr.Character:FindFirstChild("HumanoidRootPart")

            if part and hum and root and hum.Health > 0 then
                if Config.Aimbot.TeamCheck and plr.Team == player.Team then continue end

                local pos, visible = camera:WorldToScreenPoint(part.Position)
                if visible then
                    local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if dist <= Config.Aimbot.FOV and dist < minDist then
                        if Config.Aimbot.WallCheck then
                            local params = RaycastParams.new()
                            params.FilterDescendantsInstances = {player.Character}
                            params.FilterType = Enum.RaycastFilterType.Exclude
                            local ray = workspace:Raycast(camera.CFrame.Position, (part.Position - camera.CFrame.Position).Unit * 1000, params)
                            if ray and ray.Instance:FindFirstAncestor(plr.Name) then
                                closest, minDist = plr, dist
                            end
                        else
                            closest, minDist = plr, dist
                        end
                    end
                end
            end
        end
    end
    return closest
end

local function SolveAim(target)
    local part = target.Character:FindFirstChild(Config.Aimbot.TargetPart)
    local root = target.Character:FindFirstChild("HumanoidRootPart")
    if not (part and root) then return nil end

    -- Velocity-based prediction
    local velocity = root.AssemblyLinearVelocity or Vector3.zero
    local predictedPos = part.Position + velocity * Config.Aimbot.Prediction

    -- Gravity compensation for head (approximate)
    if Config.Aimbot.TargetPart == "Head" then
        predictedPos += Vector3.new(0, workspace.Gravity * Config.Aimbot.Prediction^2 * 0.5, 0)
    end

    return CFrame.lookAt(camera.CFrame.Position, predictedPos)
end

-- === ESP ENGINE ===
local ESPCache = {}
local function UpdateESP()
    if not Config.ESP.Enabled then
        for _, obj in pairs(ESPCache) do
            if obj.Box then obj.Box.Visible = false end
            if obj.Name then obj.Name.Visible = false end
        end
        return
    end
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            if hum and root and hum.Health > 0 then
                local isTeam = Config.ESP.TeamCheck and plr.Team == player.Team
                local pos, onScreen = camera:WorldToViewportPoint(root.Position)
                if not ESPCache[plr.UserId] then
                    ESPCache[plr.UserId] = { Box = Drawing.new("Square"), Name = Drawing.new("Text") }
                end
                local c = ESPCache[plr.UserId]
                c.Box.Visible = onScreen
                c.Name.Visible = onScreen
                if onScreen then
                    local scale = root.Size.Y / (pos.Z * math.tan(math.rad(camera.FieldOfView/2)) * 2) * camera.ViewportSize.Y
                    c.Box.Size = Vector2.new(scale * 0.8, scale * 1.8)
                    c.Box.Position = Vector2.new(pos.X - c.Box.Size.X/2, pos.Y - c.Box.Size.Y/2)
                    c.Box.Color = isTeam and Config.ESP.TeamColor or Config.ESP.BoxColor
                    c.Box.Thickness = 1; c.Box.Filled = false
                    c.Name.Text = plr.Name .. (isTeam and " [T]" or "")
                    c.Name.Position = Vector2.new(pos.X, pos.Y - 28)
                    c.Name.Center = true; c.Name.Outline = true
                    c.Name.Size = Config.ESP.TextSize
                    c.Name.Color = isTeam and Config.ESP.TeamColor or Config.ESP.BoxColor
                end
            end
        end
    end
end

-- === MAIN LOOP ===
RunService.RenderStepped:Connect(function(dt)
    UpdateESP()
    if not Config.Aimbot.Enabled then State.Aiming = false; State.LockedTarget = nil return end

    local target = Config.Aimbot.HoldToAim
        and (State.Aiming and GetValidTarget() or nil)
        or (State.LockedTarget and State.LockedTarget.Character and State.LockedTarget.Character:FindFirstChild(Config.Aimbot.TargetPart) and State.LockedTarget or nil)

    if target then
        local goal = SolveAim(target)
        if goal then
            -- Frame-independent smooth with adaptive clamping
            local alpha = math.clamp(Config.Aimbot.Smoothness * dt * 60, 0.01, 0.99)
            camera.CFrame = camera.CFrame:Lerp(goal, alpha)
        end
    end
end)

-- === TOUCH INPUT ===
UserInputService.TouchStarted:Connect(function(t, p)
    if p then return end
    if Config.Aimbot.Enabled and Config.Aimbot.HoldToAim then
        State.Aiming = true
    elseif Config.Aimbot.Enabled and not Config.Aimbot.HoldToAim then
        State.LockedTarget = GetValidTarget()
    end
end)
UserInputService.TouchEnded:Connect(function()
    if Config.Aimbot.HoldToAim then State.Aiming = false end
end)

