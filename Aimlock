RunService.RenderStepped:Connect(function()
    FOVCircle.Visible = Settings.FOVCircle
    FOVGlow.Visible = Settings.FOVCircle
    FOVLabel.Visible = Settings.FOVCircle
    FOVLabel.Text = tostring(Settings.FOVRadius)

    if Settings.NoRecoil then NoRecoil() end
    if Settings.InfiniteAmmo then InfiniteAmmo() end
    if Settings.Triggerbot then Triggerbot() end

    if Settings.Aimlock then
        local target = GetTargets()
        if target then
            local targetPos = target.Part + GetRandomOffset()
            local camPos = Camera.CFrame.Position
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(camPos, targetPos), Settings.AimSmoothness / 10)
        end
    end

    if Settings.ESP and hasDrawing then
        for _, esp in pairs(espObjects) do
            local player = esp.Player
            if not player then
                esp.Box.Visible = false
                esp.Name.Visible = false
                esp.Health.Visible = false
                esp.Distance.Visible = false
                continue
            end

            local character = player.Character
            if not IsAlive(character) then
                esp.Box.Visible = false
                esp.Name.Visible = false
                esp.Health.Visible = false
                esp.Distance.Visible = false
                continue
            end

            local hrp = character:FindFirstChild("HumanoidRootPart")
            if not hrp then
                esp.Box.Visible = false
                esp.Name.Visible = false
                esp.Health.Visible = false
                esp.Distance.Visible = false
                continue
            end

            local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            if not onScreen then
                esp.Box.Visible = false
                esp.Name.Visible = false
                esp.Health.Visible = false
                esp.Distance.Visible = false
                continue
            end

            local isTeammate = Settings.ESPTeam and IsTeammate(player)
            local teamColor = isTeammate and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,0,0)

            local distance = (Camera.CFrame.Position - hrp.Position).Magnitude
            local size = 150 / distance
            size = math.clamp(size, 10, 100)

            local topLeft = Vector2.new(screenPos.X - size, screenPos.Y - size * 2)
            local bottomRight = Vector2.new(screenPos.X + size, screenPos.Y + size * 0.5)

            if Settings.ESPBox then
                esp.Box.Position = topLeft
                esp.Box.Size = bottomRight - topLeft
                esp.Box.Color = teamColor
                esp.Box.Visible = true
            else
                esp.Box.Visible = false
            end

            if Settings.ESPName then
                esp.Name.Position = Vector2.new(screenPos.X, topLeft.Y - 20)
                esp.Name.Text = player.Name
                esp.Name.Color = teamColor
                esp.Name.Visible = true
            else
                esp.Name.Visible = false
            end

            if Settings.ESPHealth then
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    local healthPercent = humanoid.Health / humanoid.MaxHealth
                    local width = (bottomRight.X - topLeft.X) * healthPercent
                    esp.Health.Position = Vector2.new(topLeft.X, bottomRight.Y + 5)
                    esp.Health.Size = Vector2.new(width, 6)
                    esp.Health.Color = Color3.fromRGB(255 - 255 * healthPercent, 255 * healthPercent, 0)
                    esp.Health.Visible = true
                else
                    esp.Health.Visible = false
                end
            else
                esp.Health.Visible = false
            end

            if Settings.ESPDistance then
                esp.Distance.Position = Vector2.new(screenPos.X, bottomRight.Y + 20)
                esp.Distance.Text = string.format("%.1f m", distance)
                esp.Distance.Visible = true
            else
                esp.Distance.Visible = false
            end
        end
    end
end)

