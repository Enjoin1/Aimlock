-- === UI BUILDER HELPERS ===
local order = 0
local function AddToggle(name, default, callback)
    order += 1
    local btn = Instance.new("TextButton")
    btn.LayoutOrder = order
    btn.Text = name .. ": " .. (default and "ON" or "OFF")
    btn.Size = UDim2.new(1, -10, 0, 36)
    btn.BackgroundColor3 = default and Color3.fromRGB(0, 130, 75) or Color3.fromRGB(40, 40, 45)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.GothamMedium; btn.TextSize = 13
    btn.AutoButtonColor = false
    btn.Parent = Scroll
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.MouseButton1Click:Connect(function()
        local nv = not callback()
        btn.Text = name .. ": " .. (nv and "ON" or "OFF")
        btn.BackgroundColor3 = nv and Color3.fromRGB(0, 130, 75) or Color3.fromRGB(40, 40, 45)
        callback(nv)
    end)
    return btn
end

local function AddSlider(name, min, max, step, default, callback)
    order += 1
    local container = Instance.new("Frame")
    container.LayoutOrder = order
    container.Size = UDim2.new(1, -10, 0, 40)
    container.BackgroundTransparency = 1
    container.Parent = Scroll

    local label = Instance.new("TextLabel")
    label.Text = name .. ": " .. string.format("%.3f", default)
    label.Size = UDim2.new(0.55, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1,1,1)
    label.Font = Enum.Font.Gotham; label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = container

    local minus = Instance.new("TextButton")
    minus.Text = "−"; minus.Size = UDim2.new(0, 32, 0, 28)
    minus.Position = UDim2.new(0.58, 0, 0.5, -14)
    minus.BackgroundColor3 = Color3.fromRGB(45,45,50)
    minus.TextColor3 = Color3.new(1,1,1); minus.Font = Enum.Font.GothamBold; minus.TextSize = 16
    minus.Parent = container
    Instance.new("UICorner", minus).CornerRadius = UDim.new(0, 4)

    local plus = Instance.new("TextButton")
    plus.Text = "+"; plus.Size = UDim2.new(0, 32, 0, 28)
    plus.Position = UDim2.new(0.78, 0, 0.5, -14)
    plus.BackgroundColor3 = Color3.fromRGB(45,45,50)
    plus.TextColor3 = Color3.new(1,1,1); plus.Font = Enum.Font.GothamBold; plus.TextSize = 16
    plus.Parent = container
    Instance.new("UICorner", plus).CornerRadius = UDim.new(0, 4)

    local current = default
    local update = function(d)
        current = math.clamp(current + d, min, max)
        label.Text = name .. ": " .. string.format("%.3f", current)
        callback(current)
    end
    minus.MouseButton1Click:Connect(function() update(-step) end)
    plus.MouseButton1Click:Connect(function() update(step) end)
end

