-- === DRAG LOGIC ===
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        State.Dragging = true
        State.DragStart = input.Position
        State.MenuOffset = MenuFrame.AbsolutePosition
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if State.Dragging and input.UserInputType == Enum.UserInputType.Touch then
        local delta = input.Position - State.DragStart
        MenuFrame.Position = UDim2.new(0, State.MenuOffset.X + delta.X, 0, State.MenuOffset.Y + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        State.Dragging = false
    end
end)

