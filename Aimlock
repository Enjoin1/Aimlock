--[[
    Camera Lock-On System cho Mobile (Roblox)
    - Hỗ trợ góc nhìn thứ nhất (First-Person)
    - Tự động theo dõi đối tượng gần nhất trong tầm ngắm
    - Vòng tròn giới hạn 140px (Drawing API)
    - Kiểm tra vật cản (Raycast)
    - Nút bấm Toggle kéo thả
    - Tự động hủy khóa khi vuốt mạnh (target ra khỏi vòng tròn)
--]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- Cấu hình
local CIRCLE_RADIUS = 140          -- bán kính vòng tròn (px)
local AIM_SMOOTH = 0.7             -- độ mượt (0-1)
local MAX_TARGET_DISTANCE = 300    -- khoảng cách tối đa để tìm mục tiêu (studs)

-- Trạng thái
local isAiming = false
local currentTarget = nil
local targetHead = nil             -- vị trí head của target (Vector3)

-- Drawing: vòng tròn
local circle = Drawing.new("Circle")
circle.Thickness = 2
circle.Color = Color3.fromRGB(0, 255, 0)
circle.Filled = false
circle.Visible = false
circle.Radius = CIRCLE_RADIUS
circle.Transparency = 1

-- Cập nhật vị trí vòng tròn (tâm màn hình)
local function updateCirclePosition()
    local viewport = Camera.ViewportSize
    circle.Position = Vector2.new(viewport.X / 2, viewport.Y / 2)
end
updateCirclePosition()

-- Hàm kiểm tra tầm nhìn (Line-of-Sight)
local function hasLineOfSight(origin, targetPos)
    local direction = targetPos - origin
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.FilterDescendantsInstances = {LocalPlayer.Character, targetPos.Parent} -- bỏ qua người chơi và mục tiêu
    local result = workspace:Raycast(origin, direction, rayParams)
    return result == nil
end

-- Lấy vị trí Head của một Character
local function getHeadPosition(character)
    if not character or not character.Parent then return nil end
    local head = character:FindFirstChild("Head")
    if head then
        return head.Position
    end
    -- Nếu không có Head, lấy vị trí thân
    local torso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
    if torso then
        return torso.Position + Vector3.new(0, 1.5, 0) -- ước lượng
    end
    return nil
end

-- Tìm mục tiêu tốt nhất (gần nhất, trong tầm ngắm, có tầm nhìn)
local function findBestTarget()
    local viewport = Camera.ViewportSize
    local center = Vector2.new(viewport.X / 2, viewport.Y / 2)
    local bestScore = math.huge
    local bestCharacter = nil
    local bestHeadPos = nil

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local character = player.Character
            if character and character.Parent then
                local headPos = getHeadPosition(character)
                if headPos then
                    -- Kiểm tra khoảng cách
                    local dist = (headPos - Camera.CFrame.Position).Magnitude
                    if dist > MAX_TARGET_DISTANCE then continue end

                    -- Chuyển đổi sang tọa độ màn hình
                    local screenPos, onScreen = Camera:WorldToScreenPoint(headPos)
                    if not onScreen then continue end
                    local screenVec2 = Vector2.new(screenPos.X, screenPos.Y)

                    -- Khoảng cách tới tâm
                    local d = (screenVec2 - center).Magnitude
                    if d > CIRCLE_RADIUS then continue end

                    -- Kiểm tra tầm nhìn
                    if not hasLineOfSight(Camera.CFrame.Position, headPos) then continue end

                    -- Ưu tiên gần tâm nhất (d nhỏ nhất)
                    if d < bestScore then
                        bestScore = d
                        bestCharacter = character
                        bestHeadPos = headPos
                    end
                end
            end
        end
    end

    return bestCharacter, bestHeadPos
end

-- Kiểm tra mục tiêu hiện tại có còn hợp lệ không (nằm trong vòng tròn và có tầm nhìn)
local function isTargetValid(character, headPos)
    if not character or not character.Parent or not headPos then return false end

    local viewport = Camera.ViewportSize
    local center = Vector2.new(viewport.X / 2, viewport.Y / 2)
    local screenPos, onScreen = Camera:WorldToScreenPoint(headPos)
    if not onScreen then return false end

    local d = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
    if d > CIRCLE_RADIUS then return false end

    if not hasLineOfSight(Camera.CFrame.Position, headPos) then return false end

    return true
end

-- Cập nhật camera
local function updateCamera()
    if not isAiming then return end

    -- Nếu chưa có mục tiêu hoặc mục tiêu không hợp lệ, tìm mới
    if not currentTarget or not isTargetValid(currentTarget, targetHead) then
        local newTarget, newHead = findBestTarget()
        if newTarget then
            currentTarget = newTarget
            targetHead = newHead
        else
            -- Không có mục tiêu: không làm gì
            return
        end
    end

    -- Đảm bảo targetHead còn hợp lệ
    if not targetHead then return end

    -- Chế độ Scriptable để kiểm soát camera
    if Camera.CameraType ~= Enum.CameraType.Scriptable then
        Camera.CameraType = Enum.CameraType.Scriptable
    end

    -- Tính CFrame mong muốn: nhìn từ vị trí hiện tại đến targetHead
    local currentPos = Camera.CFrame.Position
    local desiredCF = CFrame.lookAt(currentPos, targetHead)

    -- Làm mượt (Lerp) với hệ số AIM_SMOOTH
    Camera.CFrame = Camera.CFrame:Lerp(desiredCF, AIM_SMOOTH)
end

-- Bật/Tắt hệ thống
local function toggleAim()
    isAiming = not isAiming

    if isAiming then
        -- Hiện vòng tròn
        circle.Visible = true
        updateCirclePosition()
        -- Đặt camera về Scriptable (sẽ được duy trì trong update)
        Camera.CameraType = Enum.CameraType.Scriptable
        -- Tìm mục tiêu ngay lập tức
        local newTarget, newHead = findBestTarget()
        if newTarget then
            currentTarget = newTarget
            targetHead = newHead
        end
    else
        -- Tắt: ẩn vòng tròn, reset camera về chế độ mặc định
        circle.Visible = false
        currentTarget = nil
        targetHead = nil
        -- Trả lại quyền điều khiển camera cho game
        Camera.CameraType = Enum.CameraType.Custom
    end
end

-- ===== Nút bấm Toggle (Draggable) =====
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = LocalPlayer.PlayerGui

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 70, 0, 40)
button.Position = UDim2.new(0.9, -80, 0.1, 0) -- góc phải trên
button.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
button.TextColor3 = Color3.fromRGB(255, 255, 255)
button.Text = "AIM: OFF"
button.Font = Enum.Font.SourceSansBold
button.TextSize = 16
button.BorderSizePixel = 0
button.Parent = screenGui

-- Biến kéo thả
local isDragging = false
local dragOffset = Vector2.new()

button.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.Touch then
        isDragging = true
        local position = UDim2.new(0, input.Position.X, 0, input.Position.Y)
        dragOffset = Vector2.new(input.Position.X - button.AbsolutePosition.X, input.Position.Y - button.AbsolutePosition.Y)
    end
end)

button.InputChanged:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.Touch and isDragging then
        local newX = input.Position.X - dragOffset.X
        local newY = input.Position.Y - dragOffset.Y
        local parentSize = screenGui.AbsoluteSize
        -- Giới hạn trong màn hình
        newX = math.clamp(newX, 0, parentSize.X - button.AbsoluteSize.X)
        newY = math.clamp(newY, 0, parentSize.Y - button.AbsoluteSize.Y)
        button.Position = UDim2.new(0, newX, 0, newY)
    end
end)

button.InputEnded:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.Touch then
        isDragging = false
        -- Nếu không kéo (di chuyển ít), coi như click
        -- Ở đây ta dùng MouseButton1Click cho đơn giản
    end
end)

-- Xử lý click (toggle)
button.MouseButton1Click:Connect(function()
    toggleAim()
    button.Text = isAiming and "AIM: ON" or "AIM: OFF"
end)

-- Cập nhật vòng tròn khi màn hình thay đổi kích thước
Camera:GetPropertyChangedSignal("ViewportSize"):Connect(updateCirclePosition)

-- Vòng lặp chính (RenderStepped)
RunService.RenderStepped:Connect(function()
    if isAiming then
        updateCamera()
        -- Cập nhật vòng tròn vẫn ở tâm (nếu kích thước thay đổi)
        updateCirclePosition()
    end
end)

-- Dọn dẹp khi script bị hủy (tùy chọn)
game:GetService("Players").LocalPlayer:GetPropertyChangedSignal("Character"):Connect(function()
    -- Khi nhân vật thay đổi, hủy mục tiêu
    if isAiming then
        currentTarget = nil
        targetHead = nil
    end
end)

-- Đảm bảo vòng tròn được xóa khi tắt
local function cleanup()
    circle:Remove()
    screenGui:Destroy()
end
game:GetService("RunService").Heartbeat:Connect(function()
    -- Nếu người chơi thoát, dọn dẹp
    if not LocalPlayer.Parent then
        cleanup()
    end
end)

print("Camera Lock-On System loaded successfully!")
